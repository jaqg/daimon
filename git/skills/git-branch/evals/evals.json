      "branch": "feature/auth-refactor",
      "worktree_path": "/home/user/myapp-auth-refactor",
      "current_branch": "main",
      "uncommitted_changes": false,
      "branch_exists": false,
      "path_exists": false
    },
    "expected_behavior": "Prints 'git worktree add -b feature/auth-refactor /home/user/myapp-auth-refactor'. No warning (no uncommitted changes). Reminds user to cd into worktree.",
    "must_contain": ["git worktree add -b", "feature/auth-refactor", "/home/user/myapp-auth-refactor", "cd"],
    "must_not_contain": ["Proceed?", "Warning"]
