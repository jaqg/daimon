      "commits": ["a1b2c3d feat: add parser", "e4f5g6h test: add parser tests", "x7y8z9w docs: update API"],
      "commit_count": 3,
      "diff_stat": " src/parser.py | 45 +++++\n tests/test_parser.py | 32 ++++\n docs/api.md | 8 +",
      "ff_possible": false,
