[
  {
    "id": "default_suggest_push",
    "description": "Default: uncommitted changes + ahead → suggest git-sync",
    "script_output": {
      "subcommand": "default",
      "current_branch": "main",
      "uncommitted_changes": true,
      "status_short": " M src/auth.py\n?? tests/test_auth.py",
      "tracking": {"name": "main", "upstream": "origin/main", "ahead": 3, "behind": 0},
      "linked_worktrees": [],
      "merged_stale": [],
      "recent_log": ["a1b2c3d feat(auth): add login", "e4f5g6h fix(api): null check"]
    },
    "expected_behavior": "Shows current branch=main, 3 commits ahead, uncommitted changes. Suggests running /git-sync. Does NOT suggest --clean (merged_stale is empty).",
    "must_contain": ["main", "uncommitted", "git-sync"],
    "must_not_contain": ["--clean", "git branch -d"]
  },
  {
    "id": "default_suggest_clean",
    "description": "Default: merged stale branches → suggest --clean",
    "script_output": {
      "subcommand": "default",
      "current_branch": "main",
      "uncommitted_changes": false,
      "status_short": "",
      "tracking": {"name": "main", "upstream": "origin/main", "ahead": 0, "behind": 0},
      "linked_worktrees": [{"branch": "feature/task-a", "path": "/home/user/myapp-task-a"}],
      "merged_stale": ["feature/old-auth", "fix/bug-123"],
      "recent_log": []
    },
    "expected_behavior": "Reports working tree clean. Lists linked worktree feature/task-a. Suggests /git-branch --clean for the 2 merged stale branches.",
    "must_contain": ["feature/old-auth", "fix/bug-123", "--clean", "feature/task-a"],
    "must_not_contain": ["git-sync", "git branch -d"]
  },
  {
    "id": "new_branch_commands",
